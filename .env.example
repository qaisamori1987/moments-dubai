# ── Shopify Storefront API ───────────────────────────────────────────
# Leave BOTH blank to run on built-in mock data (default during build-out).
# Fill them in to switch the whole storefront onto live Shopify data.
# See SHOPIFY_SETUP.md for how to get these.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ── WhatsApp ─────────────────────────────────────────────────────────
# Full international number, digits only. Moments' order line: 0526516021
NEXT_PUBLIC_WHATSAPP_NUMBER=971526516021

# ── Admin panel (/admin) ─────────────────────────────────────────────
# AUTH_SECRET: random 32+ byte secret that signs the admin session cookie.
#   generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
# ADMIN_PASSWORD_HASH: scrypt hash of your admin password ("salt:hash").
#   generate:  node scripts/hash-password.mjs 'your-strong-password'
ADMIN_PASSWORD_HASH=

# ── Storage ──────────────────────────────────────────────────────────
# Vercel Blob token. Empty = local dev (reads/writes src/content/*.json +
# public/images/uploads). Set automatically when you enable Blob on Vercel.
BLOB_READ_WRITE_TOKEN=
